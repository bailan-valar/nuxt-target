generator client {
  provider = "prisma-client"
  output   = "./main"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  goals     Goal[]
  folders   Folder[]
  notes     Note[]

  @@map("users")
}

enum PeriodType {
  YEAR
  MONTH
  WEEK
  TASK
  CUSTOM
}

enum FolderType {
  SCENE
  GROUP
  PROJECT
  SUBPROJECT
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_VERIFICATION
  COMPLETED
  ABANDONED
}

model Folder {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  parentId    String?     @map("parent_id")
  name        String
  type        FolderType
  description String?
  icon        String?
  color       String?
  sortOrder   Int         @default(0) @map("sort_order")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Folder?     @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    Folder[]    @relation("FolderHierarchy")
  goals       Goal[]
  notes       Note[]

  @@index([userId])
  @@index([parentId])
  @@map("folders")
}

model Goal {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  parentId    String?     @map("parent_id")
  folderId    String?     @map("folder_id")
  title       String
  description String?
  status      GoalStatus  @default(NOT_STARTED)
  periodType    PeriodType? @map("period_type")
  periodValue   String?     @map("period_value")
  sortOrder     Int         @default(0) @map("sort_order")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  plannedStart  DateTime?   @map("planned_start")
  plannedEnd    DateTime?   @map("planned_end")
  nextExecution DateTime?   @map("next_execution")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder      Folder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  parent      Goal?       @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    Goal[]      @relation("GoalHierarchy")

  @@index([folderId])
  @@map("goals")
}

model Note {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  folderId    String?  @map("folder_id")
  title       String
  content     String?
  tags        String   @default("[]")  // 存储 JSON 数组字符串
  icon        String?  @default("📄")
  isPinned    Boolean  @default(false) @map("is_pinned")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder      Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
  @@index([isPinned])
  @@map("notes")
}
