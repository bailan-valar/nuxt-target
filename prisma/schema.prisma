generator client {
  provider   = "prisma-client"
  output     = "./main"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  goals     Goal[]

  @@map("users")
}

enum PeriodType {
  YEAR
  MONTH
  WEEK
}

model Goal {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  parentId    String?     @map("parent_id")
  group       String?
  title       String
  description String?
  status      String      @default("active")
  periodType  PeriodType? @map("period_type")
  periodValue String?     @map("period_value")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Goal?       @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    Goal[]      @relation("GoalHierarchy")

  @@map("goals")
}
